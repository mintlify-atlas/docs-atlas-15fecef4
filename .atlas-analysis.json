  "keyFeatures": [
    "JSON Schema specifications for digital planning applications in England",
    "TypeScript type definitions generated from schemas",
    "Validation support via JSON Schema, AJV, and jsonschema libraries",
    "Multiple application types: planning permission, prior approval, lawful development certificates, enforcement, and more",
    "OpenAPI specification for API implementations",
    "Comprehensive example payloads for all application types",
    "API implementation guidelines with pagination, filtering, and search patterns"
  ],
  "publicApiSurface": [
    "Application schema - Main planning application specification",
    "PreApplication schema - Pre-application advice submissions",
    "PostSubmissionApplication schema - Applications after submission with validation data",
    "PostSubmissionPublishedApplication schema - Public-facing published applications",
    "PrototypeApplication schema - Prototype/experimental applications",
    "Enforcement schema - Planning enforcement reports",
    "ApplicationTypes - 80+ planning application type enums",
    "Shared types: User, Property, Proposal, Applicant, Metadata, Responses, Constraints, Materials, Fees",
    "Validation utilities for AJV and jsonschema libraries",
    "npm package exports: types/*, schemas/*, examples/*"
  ]
